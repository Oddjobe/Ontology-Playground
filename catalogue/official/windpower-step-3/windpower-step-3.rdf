<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/windpower-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/windpower-step-3/">

    <!-- Ontology Declaration -->
    <owl:Ontology rdf:about="">
        <rdfs:label>Wind Power Energy System – Step 3</rdfs:label>
        <rdfs:comment>Complete wind energy model with grid integration and battery storage.</rdfs:comment>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- Classes                  -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WindFarm">
        <rdfs:label>WindFarm</rdfs:label>
        <rdfs:comment>A wind power installation containing multiple turbines</rdfs:comment>
        <ont:icon>🏗️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Turbine">
        <rdfs:label>Turbine</rdfs:label>
        <rdfs:comment>An individual wind turbine that converts wind energy to electricity</rdfs:comment>
        <ont:icon>🌬️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#ProductionRecord">
        <rdfs:label>ProductionRecord</rdfs:label>
        <rdfs:comment>A time-series record of energy output from a turbine</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#EnvironmentalAssessment">
        <rdfs:label>EnvironmentalAssessment</rdfs:label>
        <rdfs:comment>An environmental impact assessment for a wind farm</rdfs:comment>
        <ont:icon>🌿</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#GridConnection">
        <rdfs:label>GridConnection</rdfs:label>
        <rdfs:comment>A connection point to the electricity transmission grid</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E74856</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Data Properties          -->
    <!-- ======================== -->

    <!-- WindFarm properties -->
    <owl:DatatypeProperty rdf:about="#farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#farmName">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#farmType">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#capacityMW">
        <rdfs:label>capacityMW</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#commissionYear">
        <rdfs:label>commissionYear</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Turbine properties -->
    <owl:DatatypeProperty rdf:about="#turbineId">
        <rdfs:label>turbineId</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#model">
        <rdfs:label>model</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#ratedPowerMW">
        <rdfs:label>ratedPowerMW</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#hubHeightM">
        <rdfs:label>hubHeightM</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#rotorDiameterM">
        <rdfs:label>rotorDiameterM</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#turbineStatus">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ProductionRecord properties -->
    <owl:DatatypeProperty rdf:about="#recordId">
        <rdfs:label>recordId</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#periodStart">
        <rdfs:label>periodStart</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#periodEnd">
        <rdfs:label>periodEnd</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#energyMWh">
        <rdfs:label>energyMWh</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#capacityFactor">
        <rdfs:label>capacityFactor</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#availability">
        <rdfs:label>availability</rdfs:label>
        <rdfs:domain rdf:resource="#ProductionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- EnvironmentalAssessment properties -->
    <owl:DatatypeProperty rdf:about="#assessmentId">
        <rdfs:label>assessmentId</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#assessmentDate">
        <rdfs:label>assessmentDate</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#co2AvoidedTonnes">
        <rdfs:label>co2AvoidedTonnes</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#birdIncidents">
        <rdfs:label>birdIncidents</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#noiseDecibelLevel">
        <rdfs:label>noiseDecibelLevel</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#complianceStatus">
        <rdfs:label>complianceStatus</rdfs:label>
        <rdfs:domain rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- GridConnection properties -->
    <owl:DatatypeProperty rdf:about="#connectionId">
        <rdfs:label>connectionId</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#substationName">
        <rdfs:label>substationName</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#voltageKV">
        <rdfs:label>voltageKV</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#transmissionCapacityMW">
        <rdfs:label>transmissionCapacityMW</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#connectionDate">
        <rdfs:label>connectionDate</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#hasStorageBattery">
        <rdfs:label>hasStorageBattery</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======================== -->
    <!-- Object Properties        -->
    <!-- ======================== -->

    <owl:ObjectProperty rdf:about="#farm_contains">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#Turbine"/>
        <rdfs:comment>Turbines installed in this wind farm</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>Turbine</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#turbine_generates">
        <rdfs:label>generates</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="#ProductionRecord"/>
        <rdfs:comment>Energy production records from this turbine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Turbine</ont:fromEntityId>
        <ont:toEntityId>ProductionRecord</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#farm_has_assessment">
        <rdfs:label>has_assessment</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:comment>Environmental assessments for this wind farm</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>EnvironmentalAssessment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#farm_delivers_through">
        <rdfs:label>delivers_through</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#GridConnection"/>
        <rdfs:comment>Grid connection for power delivery</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>GridConnection</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#grid_transmits">
        <rdfs:label>transmits</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="#ProductionRecord"/>
        <rdfs:comment>Production records transmitted through this connection</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>GridConnection</ont:fromEntityId>
        <ont:toEntityId>ProductionRecord</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
