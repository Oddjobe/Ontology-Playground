    <owl:ObjectProperty rdf:about="#alert_targets">
        <rdfs:label>targets</rdfs:label>
        <rdfs:domain rdf:resource="#FleetAlert"/>
        <rdfs:range rdf:resource="#Turbine"/>
        <rdfs:comment>Turbines flagged by this fleet alert</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>FleetAlert</ont:fromEntityId>
        <ont:toEntityId>Turbine</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hse_governs">
        <rdfs:label>governs</rdfs:label>
        <rdfs:domain rdf:resource="#HSEPolicy"/>
        <rdfs:range rdf:resource="#ScheduleSlot"/>
        <rdfs:comment>Schedule slots governed by this HSE rule</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>HSEPolicy</ont:fromEntityId>
        <ont:toEntityId>ScheduleSlot</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
