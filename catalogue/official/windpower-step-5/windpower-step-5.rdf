<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/windpower-step-5/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/windpower-step-5/">

    <!-- Ontology Declaration -->
    <owl:Ontology rdf:about="">
        <rdfs:label>Wind Power Energy System – Step 5</rdfs:label>
        <rdfs:comment>Extends the wind power model with weather-based scheduling, crew/vessel planning, FMECA failure analysis, cross-fleet alerts, and HSE policies (Use Cases 2-3: Weather Window and Fleet Whisperer).</rdfs:comment>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- Classes (inherited)     -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WindFarm">
        <rdfs:label>WindFarm</rdfs:label>
        <rdfs:comment>A wind power installation containing multiple turbines</rdfs:comment>
        <ont:icon>🏗️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Turbine">
        <rdfs:label>Turbine</rdfs:label>
        <rdfs:comment>An individual wind turbine that converts wind energy to electricity</rdfs:comment>
        <ont:icon>🌬️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#ProductionRecord">
        <rdfs:label>ProductionRecord</rdfs:label>
        <rdfs:comment>A time-series record of energy output from a turbine</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#EnvironmentalAssessment">
        <rdfs:label>EnvironmentalAssessment</rdfs:label>
        <rdfs:comment>An environmental impact assessment for a wind farm</rdfs:comment>
        <ont:icon>🌿</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#GridConnection">
        <rdfs:label>GridConnection</rdfs:label>
        <rdfs:comment>A connection point to the electricity transmission grid</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E74856</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Generator">
        <rdfs:label>Generator</rdfs:label>
        <rdfs:comment>The electrical generator inside a wind turbine nacelle that converts rotational energy to electricity</rdfs:comment>
        <ont:icon>⚙️</ont:icon>
        <ont:color>#8B5CF6</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Bearing">
        <rdfs:label>Bearing</rdfs:label>
        <rdfs:comment>A mechanical bearing supporting the generator shaft; a key wear component monitored for predictive maintenance</rdfs:comment>
        <ont:icon>🔩</ont:icon>
        <ont:color>#6B7280</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#SensorSignal">
        <rdfs:label>SensorSignal</rdfs:label>
        <rdfs:comment>A SCADA time-series measurement from a turbine sensor (vibration, temperature, current)</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#EF4444</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#WorkOrder">
        <rdfs:label>WorkOrder</rdfs:label>
        <rdfs:comment>A maintenance notification or work order (maps to SAP S/4HANA notification/order)</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#F59E0B</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#MaintenancePolicy">
        <rdfs:label>MaintenancePolicy</rdfs:label>
        <rdfs:comment>An IQ policy rule that defines conditions and recommended actions for condition-based maintenance</rdfs:comment>
        <ont:icon>📜</ont:icon>
        <ont:color>#10B981</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Classes (new – Step 5)  -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WeatherWindow">
        <rdfs:label>WeatherWindow</rdfs:label>
        <rdfs:comment>A forecast time window describing sea and wind conditions that determine safe access for offshore maintenance</rdfs:comment>
        <ont:icon>🌊</ont:icon>
        <ont:color>#06B6D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#CrewShift">
        <rdfs:label>CrewShift</rdfs:label>
        <rdfs:comment>A crew and vessel availability shift for offshore maintenance operations</rdfs:comment>
        <ont:icon>👷</ont:icon>
        <ont:color>#F97316</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#ScheduleSlot">
        <rdfs:label>ScheduleSlot</rdfs:label>
        <rdfs:comment>A planned maintenance time slot that aligns weather, crew, and work order constraints</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#8B5CF6</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#FailureMode">
        <rdfs:label>FailureMode</rdfs:label>
        <rdfs:comment>An FMECA failure mode describing how a component can fail, its effects, and risk priority</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#DC2626</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#FleetAlert">
        <rdfs:label>FleetAlert</rdfs:label>
        <rdfs:comment>A cross-fleet alert raised when a failure pattern is detected across multiple turbines</rdfs:comment>
        <ont:icon>🚨</ont:icon>
        <ont:color>#B91C1C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#HSEPolicy">
        <rdfs:label>HSEPolicy</rdfs:label>
        <rdfs:comment>A Health, Safety, and Environment policy rule governing offshore access conditions and crew requirements</rdfs:comment>
        <ont:icon>🛡️</ont:icon>
        <ont:color>#059669</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Data Properties (inherited from Step 1-3) -->
    <!-- ======================== -->

    <owl:DatatypeProperty rdf:about="#farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#farmName">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#farmType">
