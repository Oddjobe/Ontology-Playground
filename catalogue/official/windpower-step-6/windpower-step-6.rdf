<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/windpower-step-6/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/windpower-step-6/">

    <!-- Ontology Declaration -->
    <owl:Ontology rdf:about="">
        <rdfs:label>Wind Power Energy System – Step 6</rdfs:label>
        <rdfs:comment>Complete wind power model with warranty management, OEM bulletin tracking, financial scenario simulation (repair/derate/run-to-failure), cost tables, and AEP baselines for business-impact analysis (Use Cases 4-5: Warranty Win and Health-to-Money).</rdfs:comment>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- Classes (inherited – Step 4) -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WindFarm">
        <rdfs:label>WindFarm</rdfs:label>
        <rdfs:comment>A wind power installation containing multiple turbines</rdfs:comment>
        <ont:icon>🏗️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Turbine">
        <rdfs:label>Turbine</rdfs:label>
        <rdfs:comment>An individual wind turbine that converts wind energy to electricity</rdfs:comment>
        <ont:icon>🌬️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#ProductionRecord">
        <rdfs:label>ProductionRecord</rdfs:label>
        <rdfs:comment>A time-series record of energy output from a turbine</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#EnvironmentalAssessment">
        <rdfs:label>EnvironmentalAssessment</rdfs:label>
        <rdfs:comment>An environmental impact assessment for a wind farm</rdfs:comment>
        <ont:icon>🌿</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#GridConnection">
        <rdfs:label>GridConnection</rdfs:label>
        <rdfs:comment>A connection point to the electricity transmission grid</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E74856</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Generator">
        <rdfs:label>Generator</rdfs:label>
        <rdfs:comment>The electrical generator inside a wind turbine nacelle that converts rotational energy to electricity</rdfs:comment>
        <ont:icon>⚙️</ont:icon>
        <ont:color>#8B5CF6</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#Bearing">
        <rdfs:label>Bearing</rdfs:label>
        <rdfs:comment>A mechanical bearing supporting the generator shaft; a key wear component monitored for predictive maintenance</rdfs:comment>
        <ont:icon>🔩</ont:icon>
        <ont:color>#6B7280</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#SensorSignal">
        <rdfs:label>SensorSignal</rdfs:label>
        <rdfs:comment>A SCADA time-series measurement from a turbine sensor (vibration, temperature, current)</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#EF4444</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#WorkOrder">
        <rdfs:label>WorkOrder</rdfs:label>
        <rdfs:comment>A maintenance notification or work order (maps to SAP S/4HANA notification/order)</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#F59E0B</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#MaintenancePolicy">
        <rdfs:label>MaintenancePolicy</rdfs:label>
        <rdfs:comment>An IQ policy rule that defines conditions and recommended actions for condition-based maintenance</rdfs:comment>
        <ont:icon>📜</ont:icon>
        <ont:color>#10B981</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Classes (inherited – Step 5) -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WeatherWindow">
        <rdfs:label>WeatherWindow</rdfs:label>
        <rdfs:comment>A forecasted time window with acceptable weather conditions for offshore maintenance operations</rdfs:comment>
        <ont:icon>🌊</ont:icon>
        <ont:color>#0284C7</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#CrewShift">
        <rdfs:label>CrewShift</rdfs:label>
        <rdfs:comment>A scheduled work shift for a maintenance crew, including vessel and certification details</rdfs:comment>
        <ont:icon>👷</ont:icon>
        <ont:color>#7C3AED</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#ScheduleSlot">
        <rdfs:label>ScheduleSlot</rdfs:label>
        <rdfs:comment>A planned maintenance time slot that aligns a work order with a weather window and crew shift</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#2563EB</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#FailureMode">
        <rdfs:label>FailureMode</rdfs:label>
        <rdfs:comment>An FMECA failure mode describing how a component can fail, its effects, and detection methods</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#DC2626</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#FleetAlert">
        <rdfs:label>FleetAlert</rdfs:label>
        <rdfs:comment>A cross-fleet intelligence alert triggered when similar failure patterns are detected across multiple turbines</rdfs:comment>
        <ont:icon>🔔</ont:icon>
        <ont:color>#D97706</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#HSEPolicy">
        <rdfs:label>HSEPolicy</rdfs:label>
        <rdfs:comment>A Health, Safety &amp; Environment policy defining operational limits and safety requirements for maintenance activities</rdfs:comment>
        <ont:icon>🛡️</ont:icon>
        <ont:color>#059669</ont:color>
    </owl:Class>

    <!-- ======================== -->
    <!-- Classes (new – Step 6)  -->
    <!-- ======================== -->

    <owl:Class rdf:about="#WarrantyContract">
        <rdfs:label>WarrantyContract</rdfs:label>
        <rdfs:comment>An OEM warranty contract covering specific turbine components with defined terms, claim deadlines, and covered parts</rdfs:comment>
        <ont:icon>📃</ont:icon>
        <ont:color>#7C3AED</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#WarrantyClaim">
        <rdfs:label>WarrantyClaim</rdfs:label>
        <rdfs:comment>A warranty claim filed against an OEM contract, referencing a work order as evidence</rdfs:comment>
        <ont:icon>💼</ont:icon>
        <ont:color>#4F46E5</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#OEMBulletin">
        <rdfs:label>OEMBulletin</rdfs:label>
        <rdfs:comment>A technical bulletin issued by an OEM regarding known issues, recalls, or recommended actions for specific turbine models</rdfs:comment>
        <ont:icon>📰</ont:icon>
        <ont:color>#0EA5E9</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#FinancialScenario">
        <rdfs:label>FinancialScenario</rdfs:label>
        <rdfs:comment>A financial simulation scenario evaluating the business impact of repair, derate, or run-to-failure decisions on a work order</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#16A34A</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#CostTable">
        <rdfs:label>CostTable</rdfs:label>
        <rdfs:comment>A cost line item (CapEx, OpEx, or spare part) used in financial scenario calculations</rdfs:comment>
        <ont:icon>🧾</ont:icon>
        <ont:color>#CA8A04</ont:color>
    </owl:Class>

    <owl:Class rdf:about="#AEPBaseline">
        <rdfs:label>AEPBaseline</rdfs:label>
        <rdfs:comment>An Annual Energy Production baseline for a turbine, used to quantify energy losses and revenue impact</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#EA580C</ont:color>
    </owl:Class>

    <!-- ================================ -->
    <!-- Data Properties (inherited – Step 4: WindFarm) -->
    <!-- ================================ -->

    <owl:DatatypeProperty rdf:about="#farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#farmName">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
