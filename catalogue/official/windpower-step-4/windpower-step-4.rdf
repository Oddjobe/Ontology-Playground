    <!-- ======================== -->
    <!-- Object Properties (inherited) -->
    <!-- ======================== -->

    <owl:ObjectProperty rdf:about="#farm_contains">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#Turbine"/>
        <rdfs:comment>Turbines installed in this wind farm</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>Turbine</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#turbine_generates">
        <rdfs:label>generates</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="#ProductionRecord"/>
        <rdfs:comment>Energy production records from this turbine</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Turbine</ont:fromEntityId>
        <ont:toEntityId>ProductionRecord</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#farm_has_assessment">
        <rdfs:label>has_assessment</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#EnvironmentalAssessment"/>
        <rdfs:comment>Environmental assessments for this wind farm</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>EnvironmentalAssessment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#farm_delivers_through">
        <rdfs:label>delivers_through</rdfs:label>
        <rdfs:domain rdf:resource="#WindFarm"/>
        <rdfs:range rdf:resource="#GridConnection"/>
        <rdfs:comment>Grid connection for power delivery</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>WindFarm</ont:fromEntityId>
        <ont:toEntityId>GridConnection</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#grid_transmits">
        <rdfs:label>transmits</rdfs:label>
        <rdfs:domain rdf:resource="#GridConnection"/>
        <rdfs:range rdf:resource="#ProductionRecord"/>
        <rdfs:comment>Production records transmitted through this connection</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>GridConnection</ont:fromEntityId>
        <ont:toEntityId>ProductionRecord</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- ======================== -->
    <!-- Object Properties (new – Step 4) -->
    <!-- ======================== -->

    <owl:ObjectProperty rdf:about="#turbine_has_generator">
        <rdfs:label>has_generator</rdfs:label>
        <rdfs:domain rdf:resource="#Turbine"/>
        <rdfs:range rdf:resource="#Generator"/>
        <rdfs:comment>The electrical generator installed in this turbine</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>Turbine</ont:fromEntityId>
        <ont:toEntityId>Generator</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#generator_has_bearing">
        <rdfs:label>has_bearing</rdfs:label>
        <rdfs:domain rdf:resource="#Generator"/>
        <rdfs:range rdf:resource="#Bearing"/>
        <rdfs:comment>Mechanical bearings supporting the generator shaft</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Generator</ont:fromEntityId>
        <ont:toEntityId>Bearing</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#generator_monitored_by">
        <rdfs:label>monitored_by</rdfs:label>
        <rdfs:domain rdf:resource="#Generator"/>
        <rdfs:range rdf:resource="#SensorSignal"/>
        <rdfs:comment>SCADA sensor signals monitoring this generator</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Generator</ont:fromEntityId>
        <ont:toEntityId>SensorSignal</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#generator_has_work_order">
        <rdfs:label>has_work_order</rdfs:label>
        <rdfs:domain rdf:resource="#Generator"/>
        <rdfs:range rdf:resource="#WorkOrder"/>
        <rdfs:comment>Maintenance work orders raised for this generator</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>Generator</ont:fromEntityId>
        <ont:toEntityId>WorkOrder</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#policy_applies_to">
        <rdfs:label>applies_to</rdfs:label>
        <rdfs:domain rdf:resource="#MaintenancePolicy"/>
        <rdfs:range rdf:resource="#Generator"/>
        <rdfs:comment>The generator component this maintenance policy governs</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>MaintenancePolicy</ont:fromEntityId>
        <ont:toEntityId>Generator</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
